# sysplane-proxy 配置示例
# 放置路径：/etc/sysplane/proxy.yaml 或 ./sysplane-proxy.yaml

# hostname 是 proxy 在 center 中的唯一标识。建议以 IDC 或机房命名。
hostname: "proxy-idc-beijing"

listen:
  # grpc_address 是下游 agent 连接的 gRPC 地址。
  grpc_address: ":9091"
  tls:
    cert_file: ""
    key_file:  ""
    ca_file:   ""

upstream:
  # address 是上游节点（center 或父级 proxy）的 gRPC 地址。
  address: "center.example.com:9090"
  # token 是该 proxy 向上游认证用的 Bearer Token。
  token: "your-proxy-token-here"
  tls:
    cert_file: ""
    key_file:  ""
    ca_file:   ""

auth:
  # agent_tokens 是下游 agent 使用的 Bearer Token 列表。
  agent_tokens:
    - "your-agent-token-here"
  # proxy_tokens 是下游 proxy 使用的 Bearer Token 列表。
  proxy_tokens:
    - "your-downstream-proxy-token-here"

logging:
  level: "info"   # debug | info | warn | error
  format: "json"  # json | text
