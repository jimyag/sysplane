# sysplane-center 配置示例
# 放置路径：/etc/sysplane/center.yaml 或 ./sysplane-center.yaml

listen:
  # http_address 是 MCP/SSE HTTP 端点地址（AI 客户端连接）。
  http_address: ":8080"
  # grpc_address 是 gRPC 隧道地址（agent 和 proxy 连接）。
  grpc_address: ":9090"
  tls:
    cert_file: ""
    key_file:  ""
    ca_file:   ""

auth:
  # client_tokens 是业务调用方使用的 Bearer Token 列表。
  client_tokens:
    - "your-client-token-here"
  # admin_tokens 是管理面使用的 Bearer Token 列表。
  admin_tokens:
    - "your-admin-token-here"
  # agent_tokens 是 agent 注册使用的 Bearer Token 列表。
  agent_tokens:
    - "your-agent-token-here"
  # proxy_tokens 是 proxy 注册使用的 Bearer Token 列表。
  proxy_tokens:
    - "your-proxy-token-here"

router:
  # request_timeout_sec 是等待 agent 工具响应的最大超时秒数。默认 5。
  request_timeout_sec: 10

logging:
  level: "info"   # debug | info | warn | error
  format: "json"  # json | text
