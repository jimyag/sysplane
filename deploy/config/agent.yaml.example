# sysplane-agent 配置示例
# 放置路径：/etc/sysplane/agent.yaml 或 ./sysplane-agent.yaml

# hostname 覆盖 os.Hostname()，作为节点在 center 中的唯一标识。
# 同一台机器部署多个 agent 实例时必须手动设置，避免冲突。
hostname: "my-server-01"

upstream:
  # address 是 sysplane-center 或 sysplane-proxy 的 gRPC 地址（host:port）。必填。
  address: "center.example.com:9090"
  # token 是该 agent 向上游认证用的 Bearer Token。必填。
  token: "your-agent-token-here"
  tls:
    cert_file: ""
    key_file:  ""
    ca_file:   ""

# tool_timeout_sec 是单次工具调用的最大超时秒数。默认 25。
tool_timeout_sec: 25

# reconnect_max_delay_sec 是断线重连的最大退避间隔（秒）。默认 5。
reconnect_max_delay_sec: 5

security:
  # max_file_size_mb 限制 read_file 返回的最大文件大小。默认 100。
  max_file_size_mb: 100
  # blocked_paths 是始终拒绝访问的路径前缀列表（优先于 allowed_paths）。
  blocked_paths:
    - /proc
    - /sys
    - /dev
  # allowed_paths 非空时，仅允许访问列表中的路径前缀。
  allowed_paths: []
  # allow_privileged_ports 允许 proxy_local_api 访问 <1024 的端口。默认 false。
  allow_privileged_ports: false
  # allowed_ports 非空时，仅允许 proxy_local_api 访问列表中的端口。
  allowed_ports: []
  # allowed_commands 非空时，允许 command template / run_process 执行的绝对路径白名单。
  # 默认空列表表示禁用命令执行。
  allowed_commands: []

logging:
  level: "info"   # debug | info | warn | error
  format: "json"  # json | text
